{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Harmonica",
  "colors": {
    "primary": "#1C1917",
    "light": "#FFFFFF",
    "dark": "#0C0A09"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "faq",
              "privacy"
            ]
          },
          {
            "group": "For participants",
            "pages": [
              "guides/participants/participating-in-sessions"
            ]
          },
          {
            "group": "For hosts",
            "pages": [
              "guides/hosts/creating-sessions",
              "guides/hosts/session-design",
              "guides/hosts/session-results",
              "guides/hosts/templates",
              "guides/hosts/chains",
              "guides/hosts/widgets",
              "guides/hosts/context-sources",
              "guides/hosts/organizational-context",
              "guides/hosts/notifications",
              "guides/hosts/session-settings",
              "guides/hosts/collaboration",
              "guides/hosts/managing-projects",
              "guides/hosts/broad-listening",
              "guides/hosts/byom"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/mcp-server"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "GET /me",
              "GET /templates",
              "POST /templates",
              "GET /templates/{id}",
              "PATCH /templates/{id}",
              "DELETE /templates/{id}",
              "POST /projects",
              "GET /projects/{id}/sensemaking",
              "PATCH /projects/{id}/sensemaking",
              "POST /sessions",
              "GET /sessions",
              "GET /sessions/public",
              "GET /sessions/{id}",
              "PATCH /sessions/{id}",
              "GET /sessions/{id}/questions",
              "GET /sessions/{id}/responses",
              "POST /sessions/{id}/responses",
              "GET /sessions/{id}/session-md",
              "GET /sessions/{id}/summary",
              "POST /sessions/{id}/knowledge",
              "POST /sessions/{id}/scratchpad",
              "POST /sessions/{id}/chat",
              "POST /sessions/{id}/chat/questions"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "GET /integrations/telegram/groups",
              "POST /integrations/telegram/groups",
              "DELETE /integrations/telegram/groups/{groupId}"
            ]
          }
        ]
      }
    ],
    "global": {}
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@harmonica.chat"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Harmonica",
      "href": "https://app.harmonica.chat"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {}
  },
  "custom": {
    "css": ["/custom.css"]
  },
  "fonts": {
    "family": "Instrument Sans"
  },
  "redirects": [
    {
      "source": "/guides/hosts/project-memory",
      "destination": "/guides/hosts/organizational-context"
    }
